# Copy this to deploy/.env and fill in real values. NEVER commit the real .env.
#   cp .env.example .env  &&  nano .env

# --- Database (used by both the db container and the app) ---
DB_NAME=saafhawa
DB_USER=saafhawa
DB_PASSWORD=CHANGE_ME_strong_db_password

# --- Object storage (MinIO) for raw-payload archive ---
S3_ACCESS_KEY=CHANGE_ME_minio_user
S3_SECRET_KEY=CHANGE_ME_strong_minio_password
S3_BUCKET=saafhawa-raw

# --- App admin token (protects /admin endpoints). Use a long random string. ---
# Generate one with:  openssl rand -hex 24
SAAFHAWA_ADMIN_TOKEN=CHANGE_ME_long_random_admin_token

# --- data.gov.in API key (free; register at https://data.gov.in). ---
# Without this the app runs but cannot fetch live data.
DATAGOVIN_API_KEY=

# --- Polite contact URL sent to upstream servers ---
CONTACT_URL=https://github.com/Pravesh089/Saaf-Hawa-API
